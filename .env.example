# Required
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
WALLET_PRIVATE_KEY=your_base58_private_key

# Optional: enables gRPC slot streaming (faster, more accurate)
# Free on Helius paid plans
YELLOWSTONE_ENDPOINT=
YELLOWSTONE_TOKEN=

# Optional: override default Jito endpoint
JITO_RPC_URL=https://mainnet.block-engine.jito.wtf/api/v1

# Optional: AI mode (leave blank to use default rule-based mode)
GROQ_API_KEY=
AI_MODEL=llama-3.3-70b-versatile

# Optional: Telegram bot example
TELEGRAM_BOT_TOKEN=
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Network
SOLANA_NETWORK=mainnet-beta
